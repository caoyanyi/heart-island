<svg width="64" height="64" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="gamesGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#FF6B6B;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FF4757;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- 游戏手柄形状 -->
  <rect x="15" y="20" width="34" height="24" rx="12" fill="url(#gamesGradient)"/>
  
  <!-- 方向键 -->
  <rect x="20" y="28" width="6" height="8" fill="white"/>
  <rect x="17" y="31" width="12" height="2" fill="white"/>
  
  <!-- 按钮 -->
  <circle cx="35" cy="30" r="3" fill="white"/>
  <circle cx="42" cy="33" r="3" fill="white"/>
  <circle cx="38" cy="37" r="3" fill="white"/>
  
  <!-- 摇杆 -->
  <circle cx="25" cy="38" r="2" fill="white"/>
  
  <!-- 装饰线条 -->
  <rect x="18" y="25" width="2" height="14" fill="white" opacity="0.3"/>
  <rect x="44" y="25" width="2" height="14" fill="white" opacity="0.3"/>
</svg>