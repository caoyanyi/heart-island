<svg width="64" height="64" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="meditationGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#8A2BE2;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4B0082;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- 冥想人物轮廓 -->
  <circle cx="32" cy="20" r="8" fill="url(#meditationGradient)"/>
  
  <!-- 身体 -->
  <path d="M 24 28 Q 32 35 40 28" stroke="url(#meditationGradient)" stroke-width="3" fill="none"/>
  
  <!-- 腿部（盘坐） -->
  <path d="M 28 35 Q 25 45 20 50" stroke="url(#meditationGradient)" stroke-width="3" fill="none"/>
  <path d="M 36 35 Q 39 45 44 50" stroke="url(#meditationGradient)" stroke-width="3" fill="none"/>
  
  <!-- 手臂 -->
  <path d="M 28 32 Q 25 38 22 42" stroke="url(#meditationGradient)" stroke-width="3" fill="none"/>
  <path d="M 36 32 Q 39 38 42 42" stroke="url(#meditationGradient)" stroke-width="3" fill="none"/>
  
  <!-- 手掌 -->
  <circle cx="22" cy="42" r="2" fill="url(#meditationGradient)"/>
  <circle cx="42" cy="42" r="2" fill="url(#meditationGradient)"/>
  
  <!-- 光环效果 -->
  <circle cx="32" cy="20" r="12" stroke="url(#meditationGradient)" stroke-width="1" fill="none" opacity="0.5"/>
</svg>