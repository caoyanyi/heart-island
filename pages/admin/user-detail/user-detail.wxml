<view class="user-detail-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <button class="back-btn" bindtap="goBack">返回</button>
    <text class="page-title">用户详情</text>
    <view class="header-actions">
      <button class="action-btn" bindtap="editUserNote">备注</button>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>

  <!-- 主要内容区域 -->
  <view wx:else class="main-content">
    <!-- 用户基本信息 -->
    <view class="user-info-section">
      <view class="section-title">基本信息</view>
      <view class="info-card">
        <view class="info-item">
          <text class="label">用户ID:</text>
          <text class="value">{{userInfo.userId || '未知'}}</text>
        </view>
        <view class="info-item">
          <text class="label">昵称:</text>
          <text class="value">{{userInfo.nickName || '未设置'}}</text>
        </view>
        <view class="info-item">
          <text class="label">注册时间:</text>
          <text class="value">{{userInfo.registerTime || '未知'}}</text>
        </view>
        <view class="info-item">
          <text class="label">最后活跃:</text>
          <text class="value">{{userStats.lastActiveTime || '从未'}}</text>
        </view>
        <view wx:if="{{userInfo.adminNote}}" class="info-item">
          <text class="label">管理员备注:</text>
          <text class="value note">{{userInfo.adminNote}}</text>
        </view>
      </view>
    </view>

    <!-- 用户统计数据 -->
    <view class="stats-section">
      <view class="section-title">使用统计</view>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-number">{{userStats.totalSessions}}</text>
          <text class="stat-label">总会话数</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{userStats.totalGameTime}}</text>
          <text class="stat-label">游戏时长(分钟)</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{userStats.completedGames}}</text>
          <text class="stat-label">完成游戏</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{userStats.averageEmotionScore}}</text>
          <text class="stat-label">平均情绪分数</text>
        </view>
      </view>
      
      <view class="info-card">
        <view class="info-item">
          <text class="label">最爱游戏:</text>
          <text class="value">{{userStats.favoriteGame}}</text>
        </view>
        <view class="info-item">
          <text class="label">获得成就:</text>
          <text class="value">{{userStats.achievements.length}} 个</text>
        </view>
      </view>
    </view>

    <!-- 隐私设置 -->
    <view class="privacy-section">
      <view class="section-title">隐私设置</view>
      <view class="settings-card">
        <view class="setting-item">
          <text class="setting-label">数据收集</text>
          <switch checked="{{privacySettings.dataCollection}}" disabled="true"/>
        </view>
        <view class="setting-item">
          <text class="setting-label">个性化推荐</text>
          <switch checked="{{privacySettings.personalizedRecommendations}}" disabled="true"/>
        </view>
        <view class="setting-item">
          <text class="setting-label">广告个性化</text>
          <switch checked="{{privacySettings.advertisingPersonalization}}" disabled="true"/>
        </view>
        <view class="setting-item">
          <text class="setting-label">社交分享</text>
          <switch checked="{{privacySettings.socialSharing}}" disabled="true"/>
        </view>
      </view>
    </view>

    <!-- 广告设置 -->
    <view class="ad-section">
      <view class="section-title">广告设置</view>
      <view class="settings-card">
        <view class="setting-item">
          <text class="setting-label">横幅广告</text>
          <switch checked="{{adSettings.bannerAds}}" disabled="true"/>
        </view>
        <view class="setting-item">
          <text class="setting-label">插屏广告</text>
          <switch checked="{{adSettings.interstitialAds}}" disabled="true"/>
        </view>
        <view class="setting-item">
          <text class="setting-label">激励视频</text>
          <switch checked="{{adSettings.rewardedVideoAds}}" disabled="true"/>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions-section">
    <button class="action-btn primary" bindtap="exportUserData">导出用户数据</button>
    <button class="action-btn warning" bindtap="resetUserProgress">重置进度</button>
    <button class="action-btn danger" bindtap="deleteUserData">删除用户数据</button>
  </view>
</view>