<view class="emotion-test">
  <view class="test-header">
    <text class="test-title">情绪评估测试</text>
    <text class="test-subtitle">回答几个简单问题，了解你的情绪状态</text>
    <view class="progress-panel">
      <view class="progress-copy">
        <text class="progress-label">当前进度</text>
        <text class="progress-text">第 {{currentQuestion}} 题 / 共 {{totalQuestions}} 题</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progress}}%;"></view>
      </view>
    </view>
  </view>

  <view class="question-container" wx:if="{{!showResults}}">
    <view class="question-card">
      <view class="question-meta">
        <view class="question-number-group">
          <text class="question-kicker">Question</text>
          <text class="question-number">问题 {{currentQuestion}}</text>
        </view>
        <text class="question-tip">{{currentQuestion}} / {{totalQuestions}}</text>
      </view>
      <text class="question-text">{{questions[currentQuestion-1].text}}</text>
      <text class="question-helper">没有标准答案，选择最接近你最近一周真实感受的一项即可。</text>

      <view class="options-grid">
        <view
          class="option-item {{selectedOption === index ? 'selected' : ''}}"
          wx:for="{{questions[currentQuestion-1].options}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="selectOption"
          hover-class="none"
        >
          <view class="option-copy">
            <text class="option-index">{{index + 1}}</text>
            <text class="option-text">{{item.text}}</text>
          </view>
          <view class="option-indicator">
            <text class="option-check">✓</text>
          </view>
        </view>
      </view>
    </view>

    <view class="navigation-buttons">
      <button
        class="nav-btn prev-btn {{currentQuestion === 1 ? 'disabled' : ''}}"
        bindtap="previousQuestion"
        hover-class="none"
        disabled="{{currentQuestion === 1}}"
      >
        <text class="btn-minor">←</text>
        <text>上一题</text>
      </button>

      <button
        class="nav-btn next-btn {{selectedOption === null ? 'disabled' : ''}}"
        bindtap="nextQuestion"
        hover-class="none"
        disabled="{{selectedOption === null}}"
      >
        <text>{{currentQuestion === totalQuestions ? '完成测试' : '下一题'}}</text>
        <text class="btn-minor">→</text>
      </button>
    </view>

    <view class="secondary-actions">
      <button
        class="early-submit-btn"
        bindtap="showEarlySubmitModal"
        hover-class="none"
      >
        先看当前结果
      </button>
    </view>
  </view>

  <view class="results-container" wx:if="{{showResults}}">
    <view class="result-card">
      <text class="result-title">测试完成！</text>
      <view class="emotion-result">
        <text class="emotion-type {{primaryEmotion}}">{{emotionLabels[primaryEmotion]}}</text>
        <text class="emotion-description">{{emotionDescription}}</text>
      </view>

      <view class="score-breakdown">
        <text class="breakdown-title">详细评分</text>
        <view class="score-item" wx:for="{{emotionScores}}" wx:key="emotion">
          <text class="score-label">{{emotionLabels[item.emotion]}}</text>
          <view class="score-bar">
            <view class="score-fill {{item.emotion}}" style="width: {{item.score}}%;"></view>
          </view>
          <text class="score-value">{{item.score}}</text>
        </view>
      </view>

      <view class="recommendations">
        <text class="recommendations-title">为你推荐</text>
        <view class="recommendation-list">
          <text class="recommendation-item" wx:for="{{recommendations}}" wx:key="index">
            • {{item}}
          </text>
        </view>
      </view>
    </view>

    <view class="action-buttons">
      <button class="action-btn view-games-btn" bindtap="viewRecommendedGames">
        查看推荐游戏
      </button>
      <button class="action-btn retake-btn" bindtap="retakeTest">
        重新测试
      </button>
    </view>
  </view>
</view>
