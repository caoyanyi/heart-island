:root {
  --primary-color: #8B7D6B;
  --secondary-color: #A8A29E;
  --accent-color: #78716C;
  --background-color: #F5F5DC;
  --card-background: #FEFEFE;
  --text-primary: #374151;
  --text-secondary: #6B7280;
  --border-color: #E5E7EB;
  --success-color: #10B981;
  --warning-color: #F59E0B;
  --error-color: #EF4444;
  --calm-color: #3B82F6;
  --anxiety-color: #F59E0B;
  --low-color: #6B7280;
  --depression-color: #EF4444;
}

.emotion-test {
  --primary-color: #8F765B;
  --secondary-color: #B7A996;
  --accent-color: #675A4A;
  --background-color: #F8F1E7;
  --card-background: rgba(255, 253, 248, 0.94);
  --text-primary: #3F352B;
  --text-secondary: #8A7A67;
  --border-color: rgba(143, 118, 91, 0.16);
  --surface-shadow: rgba(85, 66, 47, 0.12);
  padding: 42rpx 30rpx 56rpx;
  background:
    radial-gradient(circle at 14% 8%, rgba(194, 221, 210, 0.64), transparent 30%),
    radial-gradient(circle at 86% 2%, rgba(230, 190, 160, 0.42), transparent 34%),
    linear-gradient(180deg, #FBF5EB 0%, var(--background-color) 48%, #EFE4D6 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.test-header {
  text-align: left;
  margin-bottom: 34rpx;
  animation: cardEnter 0.4s ease-out;
}

.test-title {
  display: block;
  font-size: 50rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.test-subtitle {
  display: block;
  font-size: 27rpx;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
  line-height: 1.5;
}

.progress-panel {
  padding: 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.64);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 12rpx 40rpx rgba(103, 90, 74, 0.08);
  backdrop-filter: blur(16rpx);
}

.progress-copy {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.progress-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.progress-bar {
  width: 100%;
  height: 14rpx;
  background: rgba(143, 118, 91, 0.12);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #A4BFAE 0%, #D6B28F 100%);
  border-radius: 999rpx;
  transition: width 0.3s ease;
  box-shadow: 0 0 18rpx rgba(164, 191, 174, 0.4);
}

.progress-text {
  font-size: 25rpx;
  color: var(--accent-color);
  font-weight: 700;
}

.question-container {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.question-card {
  background: var(--card-background);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 38rpx;
  padding: 38rpx 32rpx 34rpx;
  box-shadow: 0 22rpx 70rpx var(--surface-shadow);
  animation: cardEnter 0.35s ease-out;
  backdrop-filter: blur(18rpx);
  overflow: hidden;
  position: relative;
}

.question-card::before {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -90rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 50%;
  background: rgba(164, 191, 174, 0.18);
}

.question-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.question-number {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(164, 191, 174, 0.2);
  font-size: 24rpx;
  color: #667A68;
  font-weight: bold;
}

.question-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(143, 118, 91, 0.08);
}

.question-text {
  display: block;
  font-size: 38rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  line-height: 1.42;
  font-weight: 750;
  position: relative;
  z-index: 1;
}

.question-helper {
  display: block;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.5;
  margin-bottom: 34rpx;
  position: relative;
  z-index: 1;
}

.options-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx 28rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.78);
  transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  cursor: pointer;
  box-shadow: 0 8rpx 24rpx rgba(103, 90, 74, 0.06);
  -webkit-tap-highlight-color: transparent;
  position: relative;
  overflow: hidden;
}

.option-item:hover,
.option-item:active {
  background: rgba(255, 255, 255, 0.92);
  border-color: rgba(143, 118, 91, 0.28);
  box-shadow: 0 10rpx 26rpx rgba(103, 90, 74, 0.08);
}

.option-item.selected {
  border-color: rgba(130, 161, 139, 0.8);
  background: linear-gradient(135deg, rgba(231, 242, 233, 0.98), rgba(255, 252, 245, 0.98));
  box-shadow: 0 16rpx 40rpx rgba(104, 139, 112, 0.18);
}

.option-item.selected::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20rpx;
  bottom: 20rpx;
  width: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #91B79B, #D6B28F);
}

.option-copy {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.option-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(143, 118, 91, 0.1);
  color: #8F765B;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-item.selected .option-index {
  background: #7FA489;
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(127, 164, 137, 0.28);
}

.option-text {
  font-size: 29rpx;
  color: var(--text-primary);
  flex: 1;
  line-height: 1.48;
  font-weight: 560;
}

.option-indicator {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(143, 118, 91, 0.22);
  background: rgba(255, 255, 255, 0.72);
  transition: background-color 0.2s ease, border-color 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-item.selected .option-indicator {
  border-color: #7FA489;
  background: #7FA489;
}

.option-check {
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.option-item.selected .option-check {
  opacity: 1;
}

.navigation-buttons {
  display: flex;
  gap: 22rpx;
  justify-content: space-between;
  margin-top: 8rpx;
}

.nav-btn {
  flex: 1;
  padding: 0 34rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  transition: all 0.3s ease;
  box-shadow: none;
  text-shadow: none;
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  -webkit-tap-highlight-color: transparent;
}

.nav-btn::after,
.early-submit-btn::after {
  border: none;
}

.prev-btn {
  flex: 0.78;
  background: rgba(255, 255, 255, 0.72);
  color: var(--accent-color);
  border: 2rpx solid rgba(143, 118, 91, 0.18);
}

.next-btn {
  flex: 1.22;
  background: linear-gradient(135deg, #7FA489 0%, #C49B75 100%);
  color: #fff;
  box-shadow: 0 14rpx 34rpx rgba(127, 164, 137, 0.28);
}

.early-submit-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  padding: 0 26rpx;
  border: none;
  background: transparent;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1;
}

.secondary-actions {
  display: flex;
  justify-content: center;
  margin-top: -8rpx;
}

.nav-btn.disabled {
  opacity: 0.54;
  cursor: not-allowed;
  background: rgba(255, 255, 255, 0.72) !important;
  box-shadow: none !important;
  text-shadow: none !important;
  color: #9B8D7D !important;
}

.nav-btn:not(.disabled):hover {
  box-shadow: 0 10rpx 28rpx rgba(127, 164, 137, 0.18);
}

.nav-btn:not(.disabled):active {
  opacity: 0.88;
}

.results-container {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.result-card {
  background-color: var(--card-background);
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 40rpx;
}

.emotion-result {
  text-align: center;
  margin-bottom: 40rpx;
}

.emotion-type {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
}

.emotion-type.calm {
  color: var(--calm-color);
  background-color: rgba(59, 130, 246, 0.1);
}

.emotion-type.anxiety {
  color: var(--anxiety-color);
  background-color: rgba(245, 158, 11, 0.1);
}

.emotion-type.low {
  color: var(--low-color);
  background-color: rgba(107, 114, 128, 0.1);
}

.emotion-type.depression {
  color: var(--depression-color);
  background-color: rgba(239, 68, 68, 0.1);
}

.emotion-description {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.score-breakdown {
  margin-bottom: 40rpx;
}

.breakdown-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 30rpx;
}

.score-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.score-label {
  font-size: 28rpx;
  color: var(--text-primary);
  min-width: 100rpx;
}

.score-bar {
  flex: 1;
  height: 20rpx;
  background-color: var(--border-color);
  border-radius: 10rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.score-fill.calm {
  background-color: var(--calm-color);
}

.score-fill.anxiety {
  background-color: var(--anxiety-color);
}

.score-fill.low {
  background-color: var(--low-color);
}

.score-fill.depression {
  background-color: var(--depression-color);
}

.score-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  min-width: 60rpx;
  text-align: right;
}

.recommendations {
  background-color: var(--background-color);
  border-radius: 20rpx;
  padding: 30rpx;
}

.recommendations-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.recommendation-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.recommendation-item {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.action-buttons {
  display: flex;
  gap: 30rpx;
  justify-content: center;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  padding: 32rpx 40rpx;
  border-radius: 30rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: 4rpx solid var(--accent-color);
  transition: all 0.3s ease;
  box-shadow: 0 10rpx 30rpx rgba(120, 113, 108, 0.5);
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 300rpx;
}

.view-games-btn {
  background: linear-gradient(135deg, var(--success-color) 0%, #10b981 100%);
  border-color: var(--accent-color);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
}

.retake-btn {
  background: linear-gradient(135deg, var(--secondary-color) 0%, var(--accent-color) 100%);
  border-color: var(--accent-color);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
}

.action-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 36rpx rgba(120, 113, 108, 0.6);
}

.action-btn:active {
  transform: translateY(-1rpx);
  box-shadow: 0 6rpx 20rpx rgba(120, 113, 108, 0.4);
}

@keyframes cardEnter {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式设计 */
@media (min-width: 768px) {
  .emotion-test {
    padding: 60rpx;
  }

  .options-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .navigation-buttons {
    justify-content: center;
    max-width: 600rpx;
    margin: 40rpx auto 0;
  }

  .action-buttons {
    justify-content: center;
    max-width: 600rpx;
    margin: 0 auto;
  }
}

@media (max-width: 480px) {
  .emotion-test {
    padding: 20rpx;
  }

  .question-card {
    padding: 30rpx;
  }

  .question-meta {
    align-items: flex-start;
    flex-direction: column;
    gap: 12rpx;
  }

  .option-item {
    padding: 25rpx;
  }

  .navigation-buttons {
    flex-direction: column;
  }

  .action-buttons {
    flex-direction: column;
    gap: 20rpx;
  }

  .action-btn {
    max-width: 100%;
    margin: 0 auto;
  }
}
