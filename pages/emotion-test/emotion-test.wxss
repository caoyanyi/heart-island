:root {
  --primary-color: #8B7D6B;
  --secondary-color: #A8A29E;
  --accent-color: #78716C;
  --background-color: #F5F5DC;
  --card-background: #FEFEFE;
  --text-primary: #374151;
  --text-secondary: #6B7280;
  --border-color: #E5E7EB;
  --success-color: #10B981;
  --warning-color: #F59E0B;
  --error-color: #EF4444;
  --calm-color: #3B82F6;
  --anxiety-color: #F59E0B;
  --low-color: #6B7280;
  --depression-color: #EF4444;
}

.emotion-test {
  --primary-color: #8F765B;
  --secondary-color: #B7A996;
  --accent-color: #675A4A;
  --background-color: #F8F1E7;
  --card-background: rgba(255, 253, 248, 0.94);
  --text-primary: #3F352B;
  --text-secondary: #8A7A67;
  --border-color: rgba(143, 118, 91, 0.16);
  --surface-shadow: rgba(85, 66, 47, 0.12);
  padding: 38rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at 14% 8%, rgba(194, 221, 210, 0.64), transparent 30%),
    radial-gradient(circle at 86% 2%, rgba(230, 190, 160, 0.42), transparent 34%),
    linear-gradient(180deg, #FBF5EB 0%, var(--background-color) 48%, #EFE4D6 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.test-header {
  text-align: left;
  margin-bottom: 34rpx;
}

.test-title {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.test-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
  line-height: 1.5;
}

.progress-panel {
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(143, 118, 91, 0.08);
  box-shadow: 0 10rpx 34rpx rgba(103, 90, 74, 0.07);
  backdrop-filter: blur(16rpx);
}

.progress-copy {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.progress-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.progress-bar {
  width: 100%;
  height: 14rpx;
  background: rgba(143, 118, 91, 0.12);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #A4BFAE 0%, #D6B28F 100%);
  border-radius: 999rpx;
  transition: width 0.3s ease;
  box-shadow: 0 0 18rpx rgba(164, 191, 174, 0.4);
}

.progress-text {
  font-size: 25rpx;
  color: var(--accent-color);
  font-weight: 700;
}

.question-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.question-card {
  background: var(--card-background);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 34rpx;
  padding: 34rpx 30rpx 32rpx;
  box-shadow: 0 18rpx 54rpx rgba(85, 66, 47, 0.1);
  backdrop-filter: blur(18rpx);
  overflow: hidden;
  position: relative;
}

.question-card::before {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -90rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 50%;
  background: rgba(164, 191, 174, 0.18);
}

.question-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 26rpx;
  position: relative;
  z-index: 1;
}

.question-number-group {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.question-kicker {
  font-size: 20rpx;
  color: rgba(103, 90, 74, 0.55);
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.question-number {
  display: inline-flex;
  align-items: center;
  font-size: 30rpx;
  color: #4f624f;
  font-weight: 800;
}

.question-tip {
  font-size: 25rpx;
  color: #6f835f;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(164, 191, 174, 0.18);
  font-weight: 800;
}

.question-text {
  display: block;
  font-size: 36rpx;
  color: var(--text-primary);
  margin-bottom: 18rpx;
  line-height: 1.46;
  font-weight: 800;
  position: relative;
  z-index: 1;
}

.question-helper {
  display: block;
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 1.5;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.options-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  transition: none;
  cursor: pointer;
  box-shadow: 0 8rpx 24rpx rgba(103, 90, 74, 0.06);
  -webkit-tap-highlight-color: transparent;
  position: relative;
  overflow: hidden;
}

.option-item:hover,
.option-item:active {
  background: rgba(255, 255, 255, 0.92);
  border-color: rgba(143, 118, 91, 0.28);
  box-shadow: 0 8rpx 24rpx rgba(103, 90, 74, 0.06);
}

.option-item.selected {
  border-color: #5f8d68;
  background: #eef7ef;
  box-shadow: inset 0 0 0 2rpx rgba(95, 141, 104, 0.16), 0 8rpx 24rpx rgba(103, 90, 74, 0.06);
}

.option-item.selected::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20rpx;
  bottom: 20rpx;
  width: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #91B79B, #D6B28F);
}

.option-copy {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.option-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  background: rgba(143, 118, 91, 0.08);
  color: rgba(103, 90, 74, 0.72);
  font-size: 23rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-item.selected .option-index {
  background: #7FA489;
  color: #fff;
  box-shadow: 0 6rpx 14rpx rgba(127, 164, 137, 0.22);
}

.option-text {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  line-height: 1.48;
  font-weight: 560;
}

.option-indicator {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(143, 118, 91, 0.22);
  background: rgba(255, 255, 255, 0.72);
  transition: none;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-item.selected .option-indicator {
  border-color: #7FA489;
  background: #7FA489;
}

.option-check {
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  opacity: 0;
  transition: none;
}

.option-item.selected .option-check {
  opacity: 1;
}

.navigation-buttons {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  margin-top: 2rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(143, 118, 91, 0.1);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 12rpx 36rpx rgba(85, 66, 47, 0.08);
  backdrop-filter: blur(14rpx);
}

.nav-btn {
  flex: 1;
  gap: 10rpx;
  padding: 0 30rpx;
  border-radius: 24rpx;
  font-size: 29rpx;
  font-weight: 800;
  border: none;
  transition: none;
  box-shadow: none;
  text-shadow: none;
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  -webkit-tap-highlight-color: transparent;
  margin: 0;
  line-height: 1;
}

.nav-btn::after,
.early-submit-btn::after {
  border: none;
}

.prev-btn {
  flex: 0.82;
  background: #fffaf2;
  color: var(--accent-color);
  border: 2rpx solid rgba(143, 118, 91, 0.2);
}

.next-btn {
  flex: 1.18;
  background: #5f8d68;
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(95, 141, 104, 0.22);
}

.btn-minor {
  font-size: 26rpx;
  opacity: 0.75;
}

.early-submit-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 28rpx;
  border: none;
  border-radius: 999rpx;
  background: rgba(143, 118, 91, 0.08);
  color: #6f5d4d;
  font-size: 26rpx;
  line-height: 1;
  margin: 0;
}

.secondary-actions {
  display: flex;
  justify-content: center;
  margin-top: -8rpx;
}

.nav-btn.disabled {
  opacity: 0.54;
  cursor: not-allowed;
  background: #f2eadf !important;
  box-shadow: none !important;
  text-shadow: none !important;
  color: #9B8D7D !important;
}

.nav-btn:not(.disabled):hover {
  box-shadow: none;
}

.nav-btn:not(.disabled):active {
  opacity: 0.92;
}

.results-container {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.result-card {
  background-color: var(--card-background);
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 40rpx;
}

.emotion-result {
  text-align: center;
  margin-bottom: 40rpx;
}

.emotion-type {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
}

.emotion-type.calm {
  color: var(--calm-color);
  background-color: rgba(59, 130, 246, 0.1);
}

.emotion-type.anxiety {
  color: var(--anxiety-color);
  background-color: rgba(245, 158, 11, 0.1);
}

.emotion-type.low {
  color: var(--low-color);
  background-color: rgba(107, 114, 128, 0.1);
}

.emotion-type.depression {
  color: var(--depression-color);
  background-color: rgba(239, 68, 68, 0.1);
}

.emotion-description {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.score-breakdown {
  margin-bottom: 40rpx;
}

.breakdown-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 30rpx;
}

.score-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.score-label {
  font-size: 28rpx;
  color: var(--text-primary);
  min-width: 100rpx;
}

.score-bar {
  flex: 1;
  height: 20rpx;
  background-color: var(--border-color);
  border-radius: 10rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.score-fill.calm {
  background-color: var(--calm-color);
}

.score-fill.anxiety {
  background-color: var(--anxiety-color);
}

.score-fill.low {
  background-color: var(--low-color);
}

.score-fill.depression {
  background-color: var(--depression-color);
}

.score-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  min-width: 60rpx;
  text-align: right;
}

.recommendations {
  background-color: var(--background-color);
  border-radius: 20rpx;
  padding: 30rpx;
}

.recommendations-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.recommendation-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.recommendation-item {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.action-buttons {
  display: flex;
  gap: 30rpx;
  justify-content: center;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  padding: 32rpx 40rpx;
  border-radius: 30rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: 4rpx solid var(--accent-color);
  transition: all 0.3s ease;
  box-shadow: 0 10rpx 30rpx rgba(120, 113, 108, 0.5);
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 300rpx;
}

.view-games-btn {
  background: linear-gradient(135deg, var(--success-color) 0%, #10b981 100%);
  border-color: var(--accent-color);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
}

.retake-btn {
  background: linear-gradient(135deg, var(--secondary-color) 0%, var(--accent-color) 100%);
  border-color: var(--accent-color);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
}

.action-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 36rpx rgba(120, 113, 108, 0.6);
}

.action-btn:active {
  transform: translateY(-1rpx);
  box-shadow: 0 6rpx 20rpx rgba(120, 113, 108, 0.4);
}

@keyframes cardEnter {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式设计 */
@media (min-width: 768px) {
  .emotion-test {
    padding: 60rpx;
  }

  .options-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .navigation-buttons {
    justify-content: center;
    max-width: 600rpx;
    margin: 8rpx auto 0;
  }

  .action-buttons {
    justify-content: center;
    max-width: 600rpx;
    margin: 0 auto;
  }
}

@media (max-width: 480px) {
  .emotion-test {
    padding: 24rpx 22rpx 44rpx;
  }

  .test-title {
    font-size: 42rpx;
  }

  .progress-copy,
  .question-meta {
    align-items: flex-start;
    flex-direction: column;
    gap: 12rpx;
  }

  .question-card {
    padding: 30rpx 24rpx;
  }

  .question-text {
    font-size: 34rpx;
  }

  .option-item {
    padding: 24rpx 22rpx;
    gap: 16rpx;
  }

  .option-text {
    font-size: 27rpx;
  }

  .navigation-buttons {
    gap: 14rpx;
  }

  .nav-btn {
    min-height: 82rpx;
    padding: 0 22rpx;
    font-size: 27rpx;
  }

  .action-buttons {
    flex-direction: column;
    gap: 20rpx;
  }

  .action-btn {
    max-width: 100%;
    margin: 0 auto;
  }
}
