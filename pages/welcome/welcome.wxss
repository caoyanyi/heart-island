/* 欢迎页面样式 */
.welcome-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #F5F1EB 0%, #E8E2D5 100%);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.welcome-header {
  text-align: center;
  margin-bottom: 60rpx;
  animation: fadeInDown 0.8s ease-out;
}

.welcome-title {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #8B7355;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #8B7355 0%, #A68B5B 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.welcome-subtitle {
  font-size: 32rpx;
  color: #A68B5B;
  font-weight: 300;
  letter-spacing: 2rpx;
}

.welcome-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  max-width: 800rpx;
  margin: 0 auto;
  width: 100%;
}

.mood-checkin {
  margin-bottom: 34rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 10rpx 30rpx rgba(93, 78, 55, 0.1);
  animation: slideUp 0.6s ease-out;
}

.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 22rpx;
}

.checkin-title {
  color: #5D4E37;
  font-size: 32rpx;
  font-weight: 700;
}

.checkin-subtitle {
  margin-top: 8rpx;
  color: #8B7355;
  font-size: 24rpx;
  line-height: 1.35;
}

.mood-options {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.mood-option {
  min-width: 0;
  padding: 16rpx 6rpx;
  border-radius: 18rpx;
  background: #F8F4EE;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.mood-option.active {
  background: rgba(168, 216, 234, 0.28);
  border-color: #7FB3D3;
  transform: translateY(-2rpx);
}

.mood-icon {
  font-size: 34rpx;
  line-height: 1.1;
}

.mood-label {
  margin-top: 8rpx;
  color: #5D4E37;
  font-size: 21rpx;
  line-height: 1.15;
}

.mood-note-input {
  height: 74rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #F8F4EE;
  color: #5D4E37;
  font-size: 26rpx;
  margin-bottom: 18rpx;
}

.checkin-button {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #7FB3D3 0%, #A8D8EA 100%);
  color: white;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  padding: 0;
}

.feature-cards {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 25rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  cursor: pointer;
  animation: slideUp 0.6s ease-out;
}

.feature-card:nth-child(1) { animation-delay: 0.1s; }
.feature-card:nth-child(2) { animation-delay: 0.2s; }
.feature-card:nth-child(3) { animation-delay: 0.3s; }

.feature-card:hover {
  transform: translateY(-5rpx) scale(1.02);
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.feature-card:active {
  transform: translateY(-2rpx) scale(1.01);
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.assessment-icon {
  background: linear-gradient(135deg, #E8B4B8 0%, #D4A5A5 100%);
}

.games-icon {
  background: linear-gradient(135deg, #A8D8EA 0%, #7FB3D3 100%);
}

.progress-icon {
  background: linear-gradient(135deg, #AA96DA 0%, #9B7FB8 100%);
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #5D4E37;
  margin-bottom: 10rpx;
  display: block;
}

.card-description {
  font-size: 28rpx;
  color: #8B7355;
  line-height: 1.4;
  display: block;
}

.welcome-message {
  text-align: center;
  margin-bottom: 50rpx;
  animation: fadeIn 0.8s ease-out 0.4s both;
}

.message-text {
  font-size: 32rpx;
  color: #A68B5B;
  font-style: italic;
  position: relative;
}

.message-text::before,
.message-text::after {
  content: '"';
  font-size: 40rpx;
  color: #D4A5A5;
  position: absolute;
  top: -10rpx;
}

.message-text::before {
  left: -20rpx;
}

.message-text::after {
  right: -20rpx;
}

.welcome-footer {
  text-align: center;
  padding-top: 40rpx;
  border-top: 2rpx solid rgba(139, 115, 85, 0.2);
  animation: fadeInUp 0.8s ease-out 0.6s both;
}

.start-button {
  background: linear-gradient(135deg, #8B7355 0%, #A68B5B 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx 80rpx;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(139, 115, 85, 0.3);
  transition: all 0.3s ease;
  cursor: pointer;
}

.start-button:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 15rpx 40rpx rgba(139, 115, 85, 0.4);
}

.start-button:active {
  transform: translateY(-1rpx);
}

.footer-note {
  font-size: 24rpx;
  color: #A68B5B;
  font-style: italic;
  opacity: 0.8;
}

/* 动画效果 */
@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .welcome-container {
    padding: 30rpx 20rpx;
  }
  
  .welcome-header {
    margin-bottom: 40rpx;
  }
  
  .welcome-title {
    font-size: 56rpx;
  }
  
  .welcome-subtitle {
    font-size: 28rpx;
  }
  
  .feature-cards {
    gap: 25rpx;
    margin-bottom: 40rpx;
  }

  .mood-checkin {
    padding: 24rpx;
    margin-bottom: 28rpx;
  }

  .mood-options {
    gap: 8rpx;
  }
  
  .feature-card {
    padding: 30rpx;
  }
  
  .card-icon {
    width: 70rpx;
    height: 70rpx;
    font-size: 36rpx;
    margin-right: 25rpx;
  }
  
  .card-title {
    font-size: 32rpx;
  }
  
  .card-description {
    font-size: 26rpx;
  }
  
  .message-text {
    font-size: 28rpx;
  }
  
  .start-button {
    padding: 25rpx 70rpx;
    font-size: 32rpx;
  }
  
  .footer-note {
    font-size: 22rpx;
  }
}

@media (max-width: 600rpx) {
  .feature-card {
    padding: 25rpx;
  }
  
  .card-icon {
    width: 60rpx;
    height: 60rpx;
    font-size: 32rpx;
    margin-right: 20rpx;
  }
  
  .welcome-title {
    font-size: 48rpx;
  }
  
  .card-title {
    font-size: 28rpx;
  }
  
  .card-description {
    font-size: 24rpx;
  }
  
  .message-text {
    font-size: 26rpx;
  }
  
  .start-button {
    padding: 20rpx 60rpx;
    font-size: 28rpx;
  }
}

@media (min-width: 768px) {
  .welcome-container {
    padding: 60rpx 40rpx;
  }
  
  .welcome-header {
    margin-bottom: 80rpx;
  }
  
  .welcome-title {
    font-size: 72rpx;
  }
  
  .welcome-subtitle {
    font-size: 36rpx;
  }
  
  .feature-cards {
    gap: 40rpx;
    margin-bottom: 80rpx;
  }
  
  .feature-card {
    padding: 50rpx;
  }
  
  .card-icon {
    width: 90rpx;
    height: 90rpx;
    font-size: 44rpx;
    margin-right: 35rpx;
  }
  
  .card-title {
    font-size: 40rpx;
  }
  
  .card-description {
    font-size: 30rpx;
  }
  
  .message-text {
    font-size: 36rpx;
  }
  
  .start-button {
    padding: 35rpx 90rpx;
    font-size: 40rpx;
  }
  
  .footer-note {
    font-size: 26rpx;
  }
}
