<view class="audio-controller">
  <view class="audio-toggle" bindtap="toggleAudioPanel">
    <text class="audio-icon">{{isMuted ? '🔇' : '🎵'}}</text>
  </view>
  
  <view class="audio-panel" wx:if="{{showAudioPanel}}">
    <view class="panel-header">
      <text class="panel-title">音频设置</text>
      <text class="close-btn" bindtap="toggleAudioPanel">✕</text>
    </view>
    
    <view class="volume-control">
      <text class="control-label">音量</text>
      <slider 
        class="volume-slider"
        min="0" 
        max="1" 
        step="0.1" 
        value="{{volume}}"
        bindchange="changeVolume"
      />
      <text class="volume-text">{{Math.round(volume * 100)}}%</text>
    </view>
    
    <view class="mute-control">
      <text class="control-label">静音</text>
      <switch 
        class="mute-switch"
        checked="{{isMuted}}"
        bindchange="toggleMute"
      />
    </view>
    
    <view class="track-selection">
      <text class="control-label">背景音乐</text>
      <view class="track-grid">
        <view 
          class="track-item {{currentTrack === item.id ? 'active' : ''}}"
          wx:for="{{availableTracks}}"
          wx:key="id"
          data-track="{{item.id}}"
          bindtap="selectTrack"
        >
          <text class="track-icon">{{item.icon}}</text>
          <text class="track-name">{{item.name}}</text>
        </view>
      </view>
    </view>
    
    <view class="playback-controls">
      <button 
        class="control-btn"
        bindtap="{{isPlaying ? 'pauseAudio' : 'playAudio'}}"
      >
        {{isPlaying ? '⏸️ 暂停' : '▶️ 播放'}}
      </button>
      <button 
        class="control-btn"
        bindtap="stopAllAudio"
      >
        ⏹️ 停止
      </button>
    </view>
  </view>
  
  <!-- Audio overlay for dimming background -->
  <view 
    class="audio-overlay"
    wx:if="{{showAudioPanel}}"
    bindtap="toggleAudioPanel"
  ></view>
</view>