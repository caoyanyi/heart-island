.game-selector-container {
  --primary-beige: #E8D5C4;
  --light-beige: #F7EFE4;
  --text-primary: #4F4638;
  --text-secondary: #8A7B69;
  --primary-blue: #8DB7C7;
  --light-blue: #D8EEF2;
  --warm-pink: #D7A6A0;
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(216, 238, 242, 0.95), transparent 42%),
    linear-gradient(135deg, var(--primary-beige), var(--light-beige));
  padding: 20rpx;
}

.selector-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.back-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border: none;
  border-radius: 25rpx;
  padding: 15rpx 25rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  transition: all 0.3s ease;
}

.back-btn:hover {
  background: rgba(255, 255, 255, 0.9);
  transform: translateX(-5rpx);
}

.back-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.header-spacer {
  width: 100rpx;
}

.selector-content {
  max-width: 800rpx;
  margin: 0 auto;
}

.welcome-section {
  text-align: center;
  margin-bottom: 34rpx;
  padding: 30rpx 10rpx 10rpx;
  animation: sectionEnter 0.45s ease-out;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.welcome-prompt {
  display: inline-flex;
  margin-top: 22rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: var(--text-secondary);
  font-size: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(79, 70, 56, 0.08);
}

.games-grid {
  display: grid;
  gap: 30rpx;
  margin-bottom: 50rpx;
}

.game-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 25rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  -webkit-tap-highlight-color: transparent;
  animation: cardRise 0.45s ease-out both;
}

.game-card:hover,
.game-card:active {
  transform: translateY(-5rpx);
  box-shadow: 0 12rpx 35rpx rgba(0, 0, 0, 0.15);
  background: rgba(255, 255, 255, 0.95);
}

.game-card:nth-child(2) { animation-delay: 0.04s; }
.game-card:nth-child(3) { animation-delay: 0.08s; }
.game-card:nth-child(4) { animation-delay: 0.12s; }
.game-card:nth-child(5) { animation-delay: 0.16s; }
.game-card:nth-child(6) { animation-delay: 0.2s; }

.game-card.recommended-game {
  border: 2rpx solid rgba(141, 183, 199, 0.75);
  box-shadow: 0 12rpx 36rpx rgba(141, 183, 199, 0.22);
}

.game-card.is-loading,
.recommendation-card.is-loading {
  opacity: 0.72;
  transform: scale(0.99);
}

.game-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
  color: white;
}

.cloud-icon {
  background: linear-gradient(135deg, #87CEEB, #E0F6FF);
}

.bubble-icon {
  background: linear-gradient(135deg, #4ECDC4, #44A08D);
}

.forest-icon {
  background: linear-gradient(135deg, #98FB98, #228B22);
}

.light-icon {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

.game-info {
  flex: 1;
}

.game-badge {
  display: inline-flex;
  margin-bottom: 10rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(141, 183, 199, 0.16);
  color: #5F8B9D;
  font-size: 20rpx;
  font-weight: 700;
}

.game-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.game-description {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.4;
  margin-bottom: 15rpx;
}

.game-effect {
  font-size: 22rpx;
  color: var(--primary-blue);
  font-weight: 500;
}

.game-arrow {
  font-size: 40rpx;
  color: var(--text-secondary);
  margin-left: 20rpx;
  min-width: 34rpx;
  text-align: right;
  transition: transform 0.25s ease;
}

.game-card:active .game-arrow,
.recommendation-card:active .recommendation-arrow {
  transform: translateX(6rpx);
}

.recommendation-section {
  margin-bottom: 42rpx;
  animation: sectionEnter 0.45s ease-out;
}

.recommendation-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 18rpx;
}

.recommendation-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--warm-pink), var(--primary-blue));
  border-radius: 25rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}

.recommendation-card:hover,
.recommendation-card:active {
  transform: translateY(-5rpx);
  box-shadow: 0 12rpx 35rpx rgba(0, 0, 0, 0.2);
}

.recommendation-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: white;
}

.recommendation-content {
  flex: 1;
}

.recommendation-game-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.recommendation-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

.recommendation-arrow {
  font-size: 40rpx;
  color: white;
  margin-left: 20rpx;
  min-width: 34rpx;
  text-align: right;
  transition: transform 0.25s ease;
}

@keyframes sectionEnter {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cardRise {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* Responsive design */
@media (max-width: 750rpx) {
  .game-selector-container {
    padding: 15rpx;
  }
  
  .selector-header {
    margin-bottom: 30rpx;
  }
  
  .welcome-title {
    font-size: 42rpx;
  }
  
  .welcome-subtitle {
    font-size: 26rpx;
  }
  
  .game-card,
  .recommendation-card {
    padding: 25rpx;
  }
  
  .game-icon,
  .recommendation-icon {
    font-size: 50rpx;
    width: 70rpx;
    height: 70rpx;
    margin-right: 25rpx;
  }
  
  .game-title,
  .recommendation-game-title {
    font-size: 30rpx;
  }
  
  .game-description,
  .recommendation-text {
    font-size: 24rpx;
  }
  
  .game-effect {
    font-size: 20rpx;
  }
}

@media (max-width: 600rpx) {
  .games-grid {
    gap: 20rpx;
  }
  
  .game-card,
  .recommendation-card {
    padding: 20rpx;
  }
  
  .game-icon,
  .recommendation-icon {
    font-size: 45rpx;
    width: 60rpx;
    height: 60rpx;
    margin-right: 20rpx;
  }
  
  .game-title,
  .recommendation-game-title {
    font-size: 28rpx;
  }
  
  .game-description,
  .recommendation-text {
    font-size: 22rpx;
  }
}
