.game-selector-container {
  min-height: 100vh;
  background: linear-gradient(135deg, var(--primary-beige), var(--light-beige));
  padding: 20rpx;
}

.selector-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.back-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border: none;
  border-radius: 25rpx;
  padding: 15rpx 25rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  transition: all 0.3s ease;
}

.back-btn:hover {
  background: rgba(255, 255, 255, 0.9);
  transform: translateX(-5rpx);
}

.back-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.header-spacer {
  width: 100rpx;
}

.selector-content {
  max-width: 800rpx;
  margin: 0 auto;
}

.welcome-section {
  text-align: center;
  margin-bottom: 50rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.games-grid {
  display: grid;
  gap: 30rpx;
  margin-bottom: 50rpx;
}

.game-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 25rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  cursor: pointer;
}

.game-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 12rpx 35rpx rgba(0, 0, 0, 0.15);
  background: rgba(255, 255, 255, 0.95);
}

.game-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
  color: white;
}

.cloud-icon {
  background: linear-gradient(135deg, #87CEEB, #E0F6FF);
}

.bubble-icon {
  background: linear-gradient(135deg, #4ECDC4, #44A08D);
}

.forest-icon {
  background: linear-gradient(135deg, #98FB98, #228B22);
}

.light-icon {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

.game-info {
  flex: 1;
}

.game-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.game-description {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.4;
  margin-bottom: 15rpx;
}

.game-effect {
  font-size: 22rpx;
  color: var(--primary-blue);
  font-weight: 500;
}

.game-arrow {
  font-size: 40rpx;
  color: var(--text-secondary);
  margin-left: 20rpx;
}

.recommendation-section {
  margin-top: 60rpx;
  padding-top: 40rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.1);
}

.recommendation-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 30rpx;
}

.recommendation-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--warm-pink), var(--primary-blue));
  border-radius: 25rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
  cursor: pointer;
}

.recommendation-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 12rpx 35rpx rgba(0, 0, 0, 0.2);
}

.recommendation-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: white;
}

.recommendation-content {
  flex: 1;
}

.recommendation-game-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.recommendation-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

.recommendation-arrow {
  font-size: 40rpx;
  color: white;
  margin-left: 20rpx;
}

/* Responsive design */
@media (max-width: 750rpx) {
  .game-selector-container {
    padding: 15rpx;
  }
  
  .selector-header {
    margin-bottom: 30rpx;
  }
  
  .welcome-title {
    font-size: 42rpx;
  }
  
  .welcome-subtitle {
    font-size: 26rpx;
  }
  
  .game-card,
  .recommendation-card {
    padding: 25rpx;
  }
  
  .game-icon,
  .recommendation-icon {
    font-size: 50rpx;
    width: 70rpx;
    height: 70rpx;
    margin-right: 25rpx;
  }
  
  .game-title,
  .recommendation-game-title {
    font-size: 30rpx;
  }
  
  .game-description,
  .recommendation-text {
    font-size: 24rpx;
  }
  
  .game-effect {
    font-size: 20rpx;
  }
}

@media (max-width: 600rpx) {
  .games-grid {
    gap: 20rpx;
  }
  
  .game-card,
  .recommendation-card {
    padding: 20rpx;
  }
  
  .game-icon,
  .recommendation-icon {
    font-size: 45rpx;
    width: 60rpx;
    height: 60rpx;
    margin-right: 20rpx;
  }
  
  .game-title,
  .recommendation-game-title {
    font-size: 28rpx;
  }
  
  .game-description,
  .recommendation-text {
    font-size: 22rpx;
  }
}