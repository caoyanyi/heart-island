.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  text-align: center;
}

.logo-container {
  margin-bottom: 48rpx;
}

.app-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.1);
}

.welcome-text {
  margin-bottom: 64rpx;
}

.welcome-text .text-title {
  font-size: 48rpx;
  color: var(--deep-gray);
  margin-bottom: 16rpx;
  display: block;
}

.welcome-text .text-body {
  font-size: 28rpx;
  color: var(--secondary-gray);
  opacity: 0.8;
}

.welcome-animation {
  position: relative;
  height: 200rpx;
  width: 100%;
  margin: 32rpx 0;
}

.floating-elements {
  position: relative;
  width: 100%;
  height: 100%;
}

.cloud {
  position: absolute;
  width: 80rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 40rpx;
  opacity: 0.6;
  animation: float 6s ease-in-out infinite;
}

.cloud::before {
  content: '';
  position: absolute;
  width: 50rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  top: -25rpx;
  left: 10rpx;
}

.cloud::after {
  content: '';
  position: absolute;
  width: 60rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 40rpx;
  top: -20rpx;
  right: 10rpx;
}

.cloud-1 {
  left: 10%;
  animation-delay: 0s;
}

.cloud-2 {
  left: 50%;
  animation-delay: 2s;
}

.cloud-3 {
  left: 80%;
  animation-delay: 4s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-20px);
  }
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin: 48rpx 0;
}

.start-btn, .explore-btn {
  width: 100%;
  max-width: 400rpx;
  margin: 0 auto;
  border: 3rpx solid var(--deep-gray);
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(120, 113, 108, 0.4);
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
  padding: 28rpx 48rpx;
}

.start-btn:hover, .explore-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 10rpx 30rpx rgba(120, 113, 108, 0.5);
}

.features-section {
  display: flex;
  justify-content: space-around;
  margin-top: 64rpx;
  padding: 32rpx 0;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.feature-icon {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.7;
}

.feature-text {
  font-size: 24rpx;
  color: var(--secondary-gray);
}

/* Responsive adjustments */
@media (max-width: 750rpx) {
  .welcome-section {
    padding: 60rpx 0;
  }
  
  .app-logo {
    width: 120rpx;
    height: 120rpx;
  }
  
  .welcome-text .text-title {
    font-size: 40rpx;
  }
  
  .features-section {
    margin-top: 48rpx;
  }
}