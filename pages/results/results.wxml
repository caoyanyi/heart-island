<view class="results-container">
  <view class="results-header">
    <text class="results-title">测试结果</text>
    <text class="results-subtitle">了解你的情绪状态</text>
  </view>
  
  <view class="emotion-result">
    <view class="emotion-visual">
      <text class="emotion-icon">{{emotionIcon}}</text>
      <text class="emotion-type">{{emotionType}}</text>
    </view>
    
    <view class="emotion-description">
      <text class="description-title">你的情绪状态</text>
      <text class="description-text">{{emotionDescription}}</text>
    </view>
  </view>
  
  <view class="recommendation-section">
    <text class="section-title">为你推荐</text>
    <view class="recommended-game {{navigatingGame === recommendedGame ? 'is-loading' : ''}}" bindtap="startRecommendedGame">
      <text class="game-icon">{{recommendedGameIcon}}</text>
      <view class="game-info">
        <text class="recommendation-label">最适合现在的你</text>
        <text class="game-title">{{recommendedGameTitle}}</text>
        <text class="game-reason">{{recommendationReason}}</text>
      </view>
      <text class="game-enter">{{navigatingGame === recommendedGame ? '...' : '开始'}}</text>
    </view>
  </view>
  
  <view class="all-games-section">
    <text class="section-title">或者选择其他游戏</text>
    <view class="games-grid">
      <view 
        class="game-option {{item.id === recommendedGame ? 'recommended' : ''}} {{navigatingGame === item.id ? 'is-loading' : ''}}"
        wx:for="{{allGames}}"
        wx:key="id"
        data-game="{{item.id}}"
        bindtap="selectGame"
      >
        <text class="option-icon">{{item.icon}}</text>
        <text class="option-title">{{item.title}}</text>
        <text class="option-desc">{{item.description}}</text>
      </view>
    </view>
  </view>
  
  <view class="results-actions">
    <button class="primary-btn {{navigatingGame ? 'is-loading' : ''}}" bindtap="startRecommendedGame" disabled="{{navigatingGame !== ''}}" wx:if="{{recommendedGameTitle}}">
      <text wx:if="{{navigatingGame}}">正在进入...</text>
      <text wx:else>开始{{recommendedGameTitle}}</text>
    </button>
    <button class="primary-btn {{navigatingGame ? 'is-loading' : ''}}" bindtap="startRecommendedGame" disabled="{{navigatingGame !== ''}}" wx:else>
      {{navigatingGame ? '正在进入...' : '开始推荐游戏'}}
    </button>
    <button class="secondary-btn" bindtap="retakeTest">
      重新测试
    </button>
  </view>
</view>
