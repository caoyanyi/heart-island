.results-container {
  --primary-beige: #E8D5C4;
  --light-beige: #F7EFE4;
  --text-primary: #4F4638;
  --text-secondary: #8A7B69;
  --primary-blue: #8DB7C7;
  --light-blue: #D8EEF2;
  --warm-pink: #D7A6A0;
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(215, 166, 160, 0.24), transparent 36%),
    linear-gradient(135deg, var(--primary-beige), var(--light-beige));
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.results-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.results-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.results-subtitle {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 300;
}

.emotion-result {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 50rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  text-align: center;
  animation: resultEnter 0.45s ease-out;
}

.emotion-visual {
  margin-bottom: 40rpx;
}

.emotion-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 20rpx;
  animation: pulse 2s infinite;
}

.emotion-type {
  display: block;
  font-size: 42rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 30rpx;
}

.emotion-description {
  text-align: left;
}

.description-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.description-text {
  display: block;
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.recommendation-section {
  background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
  border-radius: 30rpx;
  padding: 40rpx;
  margin-bottom: 50rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  animation: resultEnter 0.5s ease-out 0.08s both;
}

.section-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.recommended-game {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 25rpx;
  padding: 40rpx 30rpx;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.25s ease, opacity 0.25s ease;
  -webkit-tap-highlight-color: transparent;
}

.recommended-game:active {
  transform: scale(0.985);
}

.recommended-game.is-loading,
.game-option.is-loading,
.primary-btn.is-loading {
  opacity: 0.72;
}

.game-icon {
  font-size: 90rpx;
  margin-right: 30rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.game-info {
  flex: 1;
}

.recommendation-label {
  display: inline-flex;
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.26);
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.game-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 1rpx;
}

.game-reason {
  display: block;
  font-size: 30rpx;
  line-height: 1.5;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.game-enter {
  min-width: 72rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.all-games-section {
  margin-bottom: 50rpx;
}

.all-games-section .section-title {
  color: var(--text-primary);
  margin-bottom: 40rpx;
}

.games-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 25rpx;
}

.game-option {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 25rpx;
  padding: 30rpx 25rpx;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  -webkit-tap-highlight-color: transparent;
  animation: optionEnter 0.42s ease-out both;
}

.game-option:hover,
.game-option:active {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  background: rgba(255, 255, 255, 0.95);
}

.game-option:nth-child(2) { animation-delay: 0.04s; }
.game-option:nth-child(3) { animation-delay: 0.08s; }
.game-option:nth-child(4) { animation-delay: 0.12s; }
.game-option:nth-child(5) { animation-delay: 0.16s; }
.game-option:nth-child(6) { animation-delay: 0.2s; }

.game-option.recommended {
  background: linear-gradient(135deg, var(--warm-pink), var(--primary-blue));
  position: relative;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 25rpx rgba(255, 105, 180, 0.4);
}

.game-option.recommended::before {
  content: "推荐";
  position: absolute;
  top: -15rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  color: var(--warm-pink);
  font-size: 20rpx;
  font-weight: bold;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.option-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.option-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.option-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.4;
  opacity: 0.8;
}

.results-actions {
  display: flex;
  gap: 30rpx;
  justify-content: center;
}

.primary-btn {
  flex: 2;
  padding: 30rpx 40rpx;
  border: none;
  border-radius: 50rpx;
  background: linear-gradient(135deg, var(--primary-blue), var(--warm-pink));
  font-size: 32rpx;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.3);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 1rpx;
  -webkit-tap-highlight-color: transparent;
  position: relative;
  overflow: hidden;
}

.primary-btn:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 12rpx 35rpx rgba(0, 0, 0, 0.25);
}

.primary-btn:active {
  transform: translateY(0);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.2);
}

.secondary-btn {
  flex: 1;
  padding: 30rpx 25rpx;
  border: 3rpx solid var(--primary-blue);
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.9);
  color: var(--primary-blue);
  font-size: 32rpx;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  letter-spacing: 1rpx;
  -webkit-tap-highlight-color: transparent;
  position: relative;
  overflow: hidden;
}

.secondary-btn:hover {
  background: var(--primary-blue);
  transform: translateY(-3rpx);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.25);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.secondary-btn:active {
  transform: translateY(0);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.15);
}

@keyframes resultEnter {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes optionEnter {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

/* Responsive design */
@media (max-width: 750rpx) {
  .results-container {
    padding: 30rpx 20rpx;
  }

  .results-header {
    margin-bottom: 50rpx;
  }

  .results-title {
    font-size: 48rpx;
  }

  .results-subtitle {
    font-size: 28rpx;
  }

  .emotion-result {
    padding: 40rpx 30rpx;
  }

  .emotion-icon {
    font-size: 100rpx;
  }

  .emotion-type {
    font-size: 36rpx;
  }

  .description-title {
    font-size: 28rpx;
  }

  .description-text {
    font-size: 28rpx;
  }

  .recommendation-section {
    padding: 30rpx;
  }

  .recommended-game {
    align-items: flex-start;
  }

  .section-title {
    font-size: 36rpx;
  }

  .game-icon {
    font-size: 70rpx;
  }

  .game-title {
    font-size: 32rpx;
  }

  .game-reason {
    font-size: 26rpx;
  }

  .game-enter {
    margin-top: 8rpx;
  }

  .games-grid {
    gap: 20rpx;
  }

  .game-option {
    padding: 25rpx 20rpx;
  }

  .option-icon {
    font-size: 50rpx;
  }

  .option-title {
    font-size: 28rpx;
  }

  .option-desc {
    font-size: 24rpx;
  }

  .primary-btn,
  .secondary-btn {
    font-size: 28rpx;
    padding: 25rpx 30rpx;
  }
}

@media (max-width: 600rpx) {
  .games-grid {
    grid-template-columns: 1fr;
  }

  .results-actions {
    flex-direction: column;
  }

  .primary-btn,
  .secondary-btn {
    width: 100%;
  }
}
