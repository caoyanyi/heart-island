/* 禅意拼图游戏样式 */

.zen-puzzle-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 游戏头部 */
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
}

.header-left {
  flex: 1;
}

.game-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 8rpx;
}

.game-subtitle {
  font-size: 24rpx;
  color: #7f8c8d;
  display: block;
}

.header-right {
  display: flex;
  align-items: center;
}

.back-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: 3rpx solid #2c3e50;
  border-radius: 25rpx;
  padding: 18rpx 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.back-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 25rpx rgba(102, 126, 234, 0.5);
}

/* 游戏状态栏 */
.game-status-bar {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.status-item {
  text-align: center;
  flex: 1;
}

.status-label {
  font-size: 24rpx;
  color: #7f8c8d;
  display: block;
  margin-bottom: 8rpx;
}

.status-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
}

/* 游戏区域 */
.game-area {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
  min-height: 0;
}

/* 图片加载状态 */
.loading-overlay,
.error-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 100;
  border-radius: 15rpx;
}

.loading-text,
.error-text {
  font-size: 32rpx;
  color: #7f8c8d;
  margin-bottom: 20rpx;
}

.retry-btn {
  background: #e74c3c;
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

/* 拼图网格 */
.puzzle-grid {
  display: grid;
  grid-template-columns: repeat(var(--grid-size), 1fr);
  grid-template-rows: repeat(var(--grid-size), 1fr);
  gap: 4rpx;
  background: #34495e;
  padding: 8rpx;
  border-radius: 15rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  width: 82vw;
  height: 82vw;
  max-width: 600rpx;
  max-height: 600rpx;
  box-sizing: border-box;
}

/* 拼图块 */
.puzzle-tile {
  position: relative;
  background: #ecf0f1;
  border-radius: 8rpx;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.puzzle-tile:not(.empty) {
  background: white;
}

.puzzle-tile:not(.empty):hover {
  transform: scale(1.05);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.2);
}

.puzzle-tile.empty {
  background: transparent;
  box-shadow: none;
}

.puzzle-tile.no-image {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.puzzle-tile.animating {
  animation: tileMove 0.3s ease;
}

@keyframes tileMove {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

/* 拼图块内容 */
.tile-content {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}

.tile-content-no-image {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.tile-image {
  width: 100%;
  height: 100%;
  background-size: calc(var(--grid-size) * 100%) calc(var(--grid-size) * 100%);
  background-repeat: no-repeat;
  transition: all 0.3s ease;
}

.tile-number {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(0, 0, 0, 0.7);
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  min-width: 30rpx;
  text-align: center;
}

.tile-number-large {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

/* 开始界面 */
.start-screen {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 24rpx 32rpx;
  min-height: 0;
  box-sizing: border-box;
}

.start-content {
  text-align: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  max-width: 600rpx;
  width: 100%;
  max-height: calc(100vh - 260rpx);
  overflow-y: auto;
  box-sizing: border-box;
}

.start-image {
  width: 300rpx;
  height: 200rpx;
  border-radius: 15rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #dfe9f3 0%, #ffffff 100%);
  border: 2rpx dashed rgba(102, 126, 234, 0.45);
  box-sizing: border-box;
}

.image-placeholder-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
}

.start-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 20rpx;
}

.start-description {
  font-size: 28rpx;
  color: #7f8c8d;
  display: block;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.best-scores {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.best-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 20rpx;
}

.best-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.best-label {
  font-size: 26rpx;
  color: #7f8c8d;
}

.best-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #27ae60;
}

.start-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: 3rpx solid #2c3e50;
  border-radius: 30rpx;
  padding: 28rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(120, 113, 108, 0.4);
  transition: all 0.3s ease;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
  width: 100%;
  max-width: 420rpx;
}

.start-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 10rpx 30rpx rgba(120, 113, 108, 0.5);
}

/* 完成界面 */
.completion-screen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.completion-content {
  background: white;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  max-width: 600rpx;
  width: 90%;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.3);
}

.completion-image {
  width: 300rpx;
  height: 200rpx;
  border-radius: 15rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.completion-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #27ae60;
  display: block;
  margin-bottom: 30rpx;
}

.completion-stats {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stat-item:last-child {
  margin-bottom: 0;
}

.stat-label {
  font-size: 28rpx;
  color: #7f8c8d;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.completion-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.restart-btn, .share-btn {
  flex: 1;
  padding: 24rpx 36rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 25rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 6rpx 20rpx rgba(120, 113, 108, 0.4);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.restart-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.share-btn {
  background: linear-gradient(135deg, #56ab2f 0%, #a8e6cf 100%);
  color: white;
}

.restart-btn:hover, .share-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 25rpx rgba(120, 113, 108, 0.5);
}

/* 游戏控制按钮 */
.game-controls {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 0;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.control-btn {
  padding: 24rpx 36rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 25rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  min-width: 140rpx;
  box-shadow: 0 6rpx 20rpx rgba(120, 113, 108, 0.4);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.pause-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: white;
}

.resume-btn {
  background: linear-gradient(135deg, #56ab2f 0%, #a8e6cf 100%);
  color: white;
}

.restart-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.hint-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.control-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 25rpx rgba(120, 113, 108, 0.5);
}

/* 设置面板 */
.settings-panel {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  max-width: 640rpx;
  margin: 0 auto;
  box-sizing: border-box;
}

.settings-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ecf0f1;
}

.settings-item:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.settings-label {
  font-size: 28rpx;
  color: #34495e;
}

.settings-switch {
  transform: scale(0.8);
}

/* 暂停遮罩 */
.pause-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.pause-content {
  background: white;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.3);
}

.pause-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 20rpx;
}

.pause-subtitle {
  font-size: 28rpx;
  color: #7f8c8d;
  display: block;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .puzzle-grid {
    width: 500rpx;
    height: 500rpx;
  }
  
  .start-content, .completion-content {
    padding: 40rpx 30rpx;
  }
  
  .game-controls {
    flex-wrap: wrap;
  }
  
  .control-btn {
    flex: 1;
    min-width: 100rpx;
  }
}

@media (max-width: 600rpx) {
  .puzzle-grid {
    width: 400rpx;
    height: 400rpx;
  }
  
  .game-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 20rpx;
  }
  
  .header-right {
    width: 100%;
  }
  
  .back-btn {
    width: 100%;
  }
}
