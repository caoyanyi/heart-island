<view class="light-game-container">
  <canvas 
    id="lightGameCanvas" 
    canvas-id="lightGameCanvas" 
    type="2d"
    class="game-canvas"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  ></canvas>

  <!-- Game UI -->
  <view class="game-ui">
    <view class="game-header">
      <view class="game-timer">时间: {{remainingTime}}s</view>
      <view class="game-score">分数: {{score}}</view>
    </view>
    <view class="light-indicator">
      <view class="light-text">光能: {{lightEnergy}}%</view>
      <view class="light-bar">
        <view class="light-fill" style="width: {{lightEnergy}}%"></view>
      </view>
    </view>
  </view>

  <!-- Healing Words Display -->
  <view class="healing-word-display" wx:if="{{showHealingWord}}">
    <view class="healing-word">{{currentHealingWord}}</view>
  </view>

  <!-- Instructions -->
  <view class="instructions" wx:if="{{showInstructions}}">
    <view class="instructions-title">光之治愈</view>
    <view class="instructions-text">
      点击屏幕释放光能，点亮黑暗中的星星
    </view>
    <button class="start-btn" bindtap="startGame">开始游戏</button>
  </view>

  <!-- Game Over -->
  <view class="game-over" wx:if="{{gameOver}}">
    <view class="game-over-title">游戏结束</view>
    <view class="completion-message">{{completionMessage}}</view>
    <view class="final-score">{{score}} 分</view>
    <view class="game-over-buttons">
      <button class="btn-primary" bindtap="playAgain">再玩一次</button>
    </view>
  </view>
</view>