<view class="cloud-drifting-game">
  <view class="game-canvas-container">
    <canvas
      id="cloudCanvas"
      type="2d"
      class="game-canvas"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
      style="pointer-events: {{gameStatus === 'playing' ? 'auto' : 'none'}}; visibility: {{gameStatus === 'playing' ? 'visible' : 'hidden'}};"
    ></canvas>

    <view class="game-ui" wx:if="{{gameStatus === 'playing'}}">
      <view class="score-display">
        <text class="score-label">得分</text>
        <text class="score-value">{{score}}</text>
      </view>

      <view class="time-display">
        <text class="time-label">时间</text>
        <text class="time-value">{{timeLeft}}</text>
      </view>

      <view class="combo-display" wx:if="{{combo > 1}}">
        <text class="combo-text">连击 x{{combo}}</text>
      </view>
    </view>

    <view class="play-hint" wx:if="{{gameStatus === 'playing' && score === 0}}">
      按住拖动白云，收集气泡并避开乌云
    </view>

  </view>

  <cover-view class="entry-panel" wx:if="{{gameStatus !== 'playing'}}">
    <cover-view class="entry-card">
      <cover-view class="entry-visual">
        <cover-view class="entry-cloud cloud-main">☁</cover-view>
        <cover-view class="entry-bubble bubble-one"></cover-view>
        <cover-view class="entry-bubble bubble-two"></cover-view>
        <cover-view class="entry-bubble bubble-three"></cover-view>
      </cover-view>
      <cover-view class="status-title">{{statusTitle}}</cover-view>
      <cover-view class="status-message">{{statusMessage}}</cover-view>
      <cover-view class="status-tips" wx:if="{{gameStatus === 'ready' || gameStatus === 'paused'}}">
        <cover-view class="tip-item">拖动白云：控制移动方向</cover-view>
        <cover-view class="tip-item">透明气泡：获得分数和连击</cover-view>
        <cover-view class="tip-item">乌云障碍：碰到会扣分</cover-view>
      </cover-view>
      <cover-view class="game-btn primary-btn" wx:if="{{gameStatus === 'paused'}}" bindtap="resumeGame">
        继续游戏
      </cover-view>
      <cover-view class="game-btn primary-btn disabled-btn" wx:elif="{{gameStatus === 'loading'}}">
        加载中...
      </cover-view>
      <cover-view class="game-btn primary-btn" wx:else bindtap="startGame">{{gameButtonText}}</cover-view>
      <cover-view class="entry-secondary-btn" bindtap="openSettings">游戏设置</cover-view>
    </cover-view>
  </cover-view>

  <view class="game-controls" wx:if="{{gameStatus === 'playing' || gameStatus === 'paused'}}">
    <button class="control-btn pause-btn" bindtap="pauseGame" wx:if="{{gameStatus === 'playing'}}">
      <text class="btn-icon">⏸️</text>
      暂停
    </button>

    <button class="control-btn resume-btn" bindtap="resumeGame" wx:if="{{gameStatus === 'paused'}}">
      <text class="btn-icon">▶️</text>
      继续
    </button>

    <button class="control-btn restart-btn" bindtap="restartGame">
      <text class="btn-icon">🔄</text>
      重新开始
    </button>

    <button class="control-btn settings-btn" bindtap="openSettings">
      <text class="btn-icon">⚙️</text>
      设置
    </button>
  </view>

  <view class="game-settings" wx:if="{{showSettings}}">
    <view class="settings-panel">
      <view class="settings-header">
        <text class="settings-title">游戏设置</text>
        <button class="close-btn" bindtap="closeSettings">✕</button>
      </view>

      <view class="setting-group">
        <text class="setting-label">音效</text>
        <switch checked="{{soundEnabled}}" bindchange="toggleSound"></switch>
      </view>

      <view class="setting-group">
        <text class="setting-label">背景音乐</text>
        <switch checked="{{musicEnabled}}" bindchange="toggleMusic"></switch>
      </view>

      <view class="setting-group">
        <text class="setting-label">游戏时长</text>
        <picker bindchange="changeGameDuration" value="{{gameDurationIndex}}" range="{{durationOptions}}">
          <view class="picker-value">{{durationOptions[gameDurationIndex]}}</view>
        </picker>
      </view>
    </view>
  </view>
</view>
