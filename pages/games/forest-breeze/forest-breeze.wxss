.forest-game-container {
  --primary-blue: #4f8f6b;
  --light-blue: #bfe8d1;
  --warm-pink: #d99173;
  --text-secondary: #5f715f;
  --text-primary: #244731;
  --light-gray: rgba(255, 255, 255, 0.86);
  --medium-gray: rgba(229, 238, 226, 0.96);
  position: relative;
  width: 100%;
  height: 100vh;
  background: linear-gradient(to bottom, #87CEEB, #98FB98, #228B22);
  overflow: hidden;
}

.game-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.game-ui {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  z-index: 10;
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.game-timer {
  background: rgba(255, 255, 255, 0.9);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--primary-blue);
  font-weight: bold;
}

.game-score {
  background: rgba(255, 255, 255, 0.9);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--warm-pink);
  font-weight: bold;
}

.wind-indicator {
  background: rgba(255, 255, 255, 0.9);
  padding: 15rpx 20rpx;
  border-radius: 20rpx;
  margin-top: 10rpx;
}

.wind-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  text-align: center;
}

.wind-bar {
  width: 200rpx;
  height: 8rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
  margin: 0 auto;
}

.wind-fill {
  height: 100%;
  background: linear-gradient(to right, var(--light-blue), var(--primary-blue));
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.quick-controls {
  position: absolute;
  right: 24rpx;
  bottom: 36rpx;
  z-index: 16;
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  min-width: 104rpx;
  min-height: 68rpx;
  padding: 0 24rpx;
  border: none;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #2f5f3a;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 28rpx rgba(24, 80, 42, 0.18);
  backdrop-filter: blur(12rpx);
}

.quick-btn.primary {
  background: linear-gradient(135deg, #5fa66f, #9fcf86);
  color: #fff;
}

.quick-btn::after,
.start-btn::after,
.btn-primary::after,
.btn-secondary::after {
  border: none;
}

.pause-overlay {
  position: absolute;
  inset: 0;
  z-index: 24;
  background: rgba(23, 53, 35, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.pause-card {
  width: 100%;
  max-width: 560rpx;
  padding: 48rpx 40rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(18, 55, 31, 0.25);
}

.pause-title {
  font-size: 38rpx;
  color: #2f5f3a;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.pause-text {
  font-size: 28rpx;
  color: #6b7f68;
  line-height: 1.5;
  margin-bottom: 30rpx;
}

.instructions {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(255, 255, 255, 0.95);
  padding: 40rpx;
  border-radius: 20rpx;
  text-align: center;
  max-width: 80%;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.instructions-title {
  font-size: 36rpx;
  color: var(--primary-blue);
  margin-bottom: 20rpx;
  font-weight: bold;
}

.instructions-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 30rpx;
}

.start-btn {
  background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.start-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.25);
}

.game-over {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(255, 255, 255, 0.95);
  padding: 40rpx;
  border-radius: 20rpx;
  text-align: center;
  max-width: 80%;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.game-over-title {
  font-size: 36rpx;
  color: var(--primary-blue);
  margin-bottom: 20rpx;
  font-weight: bold;
}

.completion-message {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.final-score {
  font-size: 48rpx;
  color: var(--warm-pink);
  font-weight: bold;
  margin-bottom: 30rpx;
}

.game-over-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.btn-secondary {
  background: var(--light-gray);
  color: var(--text-primary);
  padding: 20rpx 30rpx;
  border-radius: 25rpx;
  font-size: 28rpx;
  border: none;
  transition: all 0.3s ease;
}

.btn-secondary:hover {
  background: var(--medium-gray);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-blue), var(--light-blue));
  padding: 20rpx 30rpx;
  border-radius: 25rpx;
  font-size: 28rpx;
  border: none;
  transition: all 0.3s ease;
}

.btn-primary:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* Touch controls */
.touch-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
}

/* Leaf animations */
@keyframes leaf-fall {
  0% {
    transform: translateY(-50rpx) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(360deg);
    opacity: 0.3;
  }
}

.leaf-fall {
  animation: leaf-fall 8s linear infinite;
}

@keyframes wind-sway {
  0%, 100% {
    transform: translateX(0) rotate(0deg);
  }
  25% {
    transform: translateX(10rpx) rotate(5deg);
  }
  75% {
    transform: translateX(-10rpx) rotate(-5deg);
  }
}

.wind-sway {
  animation: wind-sway 2s ease-in-out infinite;
}

/* Responsive design */
@media (max-width: 750rpx) {
  .instructions,
  .game-over {
    max-width: 90%;
    padding: 30rpx;
  }

  .instructions-title,
  .game-over-title {
    font-size: 32rpx;
  }

  .instructions-text,
  .completion-message {
    font-size: 26rpx;
  }

  .final-score {
    font-size: 42rpx;
  }

  .game-over-buttons {
    flex-direction: column;
    align-items: center;
  }

  .btn-secondary,
  .btn-primary {
    width: 100%;
    max-width: 300rpx;
  }

  .wind-indicator {
    max-width: 300rpx;
    margin: 10rpx auto 0;
  }

  .wind-bar {
    width: 150rpx;
  }
}
