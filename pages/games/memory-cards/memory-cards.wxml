<!-- 记忆卡片游戏页面 -->
<view class="memory-cards-container">
  <!-- 游戏头部 -->
  <view class="game-header">
    <view class="header-left">
      <text class="game-title">记忆卡片</text>
      <text class="game-subtitle">锻炼记忆力，提升专注力</text>
    </view>
    <view class="header-right">
    </view>
  </view>

  <!-- 游戏状态栏 -->
  <view class="game-status-bar">
    <view class="status-item">
      <text class="status-label">时间</text>
      <text class="status-value">{{formatTime(timeLeft)}}</text>
    </view>
    <view class="status-item">
      <text class="status-label">匹配</text>
      <text class="status-value">{{matches}}</text>
    </view>
    <view class="status-item">
      <text class="status-label">尝试</text>
      <text class="status-value">{{attempts}}</text>
    </view>
    <view class="status-item">
      <text class="status-label">得分</text>
      <text class="status-value">{{score}}</text>
    </view>
  </view>

  <!-- 连击显示 -->
  <view class="combo-display" wx:if="{{comboCount > 1}}">
    <text class="combo-text">{{comboCount}}连击！</text>
    <text class="combo-multiplier">x{{comboMultiplier}}</text>
  </view>

  <!-- 游戏区域 -->
  <view class="game-area" wx:if="{{gameStatus !== 'ready'}}">
    <!-- 卡片网格 -->
    <view class="cards-grid" style="--grid-size: {{gridSize}};">
      <block wx:for="{{cards}}" wx:for-item="row" wx:for-index="rowIndex" wx:key="rowIndex">
        <view wx:for="{{row}}" wx:for-item="card" wx:for-index="colIndex" wx:key="colIndex"
              class="memory-card {{card.isFlipped ? 'flipped' : ''}} {{card.isMatched ? 'matched' : ''}} {{animatingCards.includes(rowIndex + '-' + colIndex) ? 'animating' : ''}}"
              style="grid-row: {{rowIndex + 1}}; grid-column: {{colIndex + 1}};"
              bindtap="onCardTap"
              data-row="{{rowIndex}}"
              data-col="{{colIndex}}">
          
          <!-- 卡片正面 -->
          <view class="card-front">
            <text class="card-symbol">{{card.content}}</text>
          </view>
          
          <!-- 卡片背面 -->
          <view class="card-back">
            <view class="back-pattern"></view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 开始界面 -->
  <view class="start-screen" wx:if="{{gameStatus === 'ready'}}">
    <view class="start-content">
      <text class="start-title">记忆卡片</text>
      <text class="start-description">翻牌配对，挑战你的记忆力极限</text>
      
      <!-- 主题选择 -->
      <view class="theme-selection">
        <text class="theme-title">选择主题</text>
        <view class="theme-options">
          <view class="theme-option {{cardTheme === 'nature' ? 'active' : ''}}" 
                data-theme="nature" 
                bindtap="changeTheme">
            <text class="theme-icon">🌸</text>
            <text class="theme-label">自然</text>
          </view>
          <view class="theme-option {{cardTheme === 'animals' ? 'active' : ''}}" 
                data-theme="animals" 
                bindtap="changeTheme">
            <text class="theme-icon">🐶</text>
            <text class="theme-label">动物</text>
          </view>
          <view class="theme-option {{cardTheme === 'symbols' ? 'active' : ''}}" 
                data-theme="symbols" 
                bindtap="changeTheme">
            <text class="theme-icon">❤️</text>
            <text class="theme-label">符号</text>
          </view>
        </view>
      </view>
      
      <!-- 最佳成绩 -->
      <view class="best-scores" wx:if="{{bestTime || bestScore}}">
        <text class="best-title">最佳成绩</text>
        <view class="best-item" wx:if="{{bestTime}}">
          <text class="best-label">最快时间：</text>
          <text class="best-value">{{formatTime(bestTime)}}</text>
        </view>
        <view class="best-item" wx:if="{{bestScore}}">
          <text class="best-label">最高得分：</text>
          <text class="best-value">{{bestScore}}</text>
        </view>
      </view>
      
      <button class="start-btn" bindtap="startGame">开始游戏</button>
    </view>
  </view>

  <!-- 完成界面 -->
  <view class="completion-screen" wx:if="{{gameStatus === 'completed'}}">
    <view class="completion-content">
      <text class="completion-title">恭喜完成！</text>
      <view class="completion-stats">
        <view class="stat-item">
          <text class="stat-label">用时</text>
          <text class="stat-value">{{formatTime(completionTime)}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">匹配数</text>
          <text class="stat-value">{{matches}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">尝试次数</text>
          <text class="stat-value">{{attempts}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">准确率</text>
          <text class="stat-value">{{attempts > 0 ? Math.floor((matches / attempts) * 100) : 0}}%</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">最高连击</text>
          <text class="stat-value">{{maxCombo}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">最终得分</text>
          <text class="stat-value">{{score}}</text>
        </view>
      </view>
      <view class="completion-actions">
        <button class="restart-btn" bindtap="restartGame">再玩一次</button>
        <button class="share-btn" open-type="share">分享成绩</button>
      </view>
    </view>
  </view>

  <!-- 游戏控制按钮 -->
  <view class="game-controls" wx:if="{{gameStatus === 'playing' || gameStatus === 'paused'}}">
    <button class="control-btn pause-btn" wx:if="{{gameStatus === 'playing'}}" bindtap="pauseGame">
      暂停
    </button>
    <button class="control-btn resume-btn" wx:if="{{gameStatus === 'paused'}}" bindtap="resumeGame">
      继续
    </button>
    <button class="control-btn restart-btn" bindtap="restartGame">
      重新开始
    </button>
    <button class="control-btn hint-btn" bindtap="getHint">
      提示
    </button>
  </view>

  <!-- 设置面板 -->
  <view class="settings-panel">
    <view class="settings-item">
      <text class="settings-label">音效</text>
      <switch class="settings-switch" checked="{{soundEnabled}}" bindchange="toggleSound"></switch>
    </view>
  </view>

  <!-- 暂停遮罩 -->
  <view class="pause-overlay" wx:if="{{gameStatus === 'paused'}}">
    <view class="pause-content">
      <text class="pause-title">游戏已暂停</text>
      <text class="pause-subtitle">点击继续按钮恢复游戏</text>
    </view>
  </view>
</view>