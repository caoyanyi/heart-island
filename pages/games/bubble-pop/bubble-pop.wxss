/* 气泡爆破游戏样式 */
page {
  background: linear-gradient(135deg, #4ECDC4 0%, #E0F6FF 100%);
  height: 100vh;
  overflow: hidden;
  position: relative;
}

.bubble-pop-game {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 游戏头部 */
.game-header {
  position: relative;
  z-index: 10;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.score-display {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
}

.score-label {
  font-size: 28rpx;
  color: #7F8C8D;
  display: block;
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #E74C3C;
  display: block;
}

.score-number {
  color: #E74C3C;
  font-size: 42rpx;
}

.time-display {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
}

.time-label {
  font-size: 28rpx;
  color: #7F8C8D;
  display: block;
  margin-bottom: 8rpx;
}

.time-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #3498DB;
  display: block;
}

.game-controls {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 15rpx;
  z-index: 10;
  flex-wrap: wrap;
  justify-content: center;
  max-width: 90%;
}

.control-btn {
  background: linear-gradient(135deg, #4ECDC4 0%, #45B7D1 100%);
  border: none;
  border-radius: 30rpx;
  padding: 15rpx 20rpx;
  font-size: 24rpx;
  color: white;
  font-weight: 500;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 16rpx rgba(78, 205, 196, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 100rpx;
  max-width: 120rpx;
  flex: 1;
}

.control-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 8rpx rgba(78, 205, 196, 0.2);
}

/* 游戏画布 */
.game-canvas-container {
  position: absolute;
  top: 100rpx;
  left: 30rpx;
  right: 30rpx;
  bottom: 140rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.15);
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(5px);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  z-index: 1;
}

#bubbleCanvas {
  width: 100%;
  height: 100%;
  display: block;
  background: transparent;
}

/* 游戏UI覆盖层 */
.game-ui {
  position: absolute;
  top: 40rpx;
  left: 40rpx;
  right: 40rpx;
  pointer-events: none;
  z-index: 5;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

/* 游戏状态覆盖层 */
.game-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 100;
  transition: opacity 0.3s ease;
}

.overlay-content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  max-width: 80%;
  animation: slideUp 0.5s ease-out;
}

.overlay-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 20rpx;
}

.overlay-message {
  font-size: 32rpx;
  color: #7F8C8D;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.overlay-score {
  font-size: 36rpx;
  color: #E74C3C;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.overlay-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.game-button {
  background: linear-gradient(135deg, #4ECDC4 0%, #45B7D1 100%);
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 25rpx 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 24rpx rgba(78, 205, 196, 0.4);
  transition: all 0.3s ease;
  margin: 10rpx;
  min-width: 200rpx;
}

.game-button:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 15rpx 30rpx rgba(78, 205, 196, 0.4);
}

.game-button:active {
  transform: scale(0.95);
  box-shadow: 0 6rpx 12rpx rgba(78, 205, 196, 0.2);
}

.secondary-button {
  background: linear-gradient(135deg, #95A5A6 0%, #7F8C8D 100%);
  box-shadow: 0 10rpx 20rpx rgba(149, 165, 166, 0.3);
  border-radius: 30rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  margin: 10rpx;
  min-width: 180rpx;
}

.secondary-button:hover {
  box-shadow: 0 15rpx 30rpx rgba(149, 165, 166, 0.4);
}

.secondary-button:active {
  transform: scale(0.95);
  box-shadow: 0 5rpx 10rpx rgba(149, 165, 166, 0.2);
}

/* 状态覆盖层 */
.status-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 40rpx;
  padding: 80rpx 60rpx;
  text-align: center;
  box-shadow: 0 30rpx 60rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(20px);
  width: 90%;
  max-width: 600rpx;
  min-width: 500rpx;
  animation: slideUp 0.5s ease-out;
  pointer-events: auto;
  z-index: 100;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.status-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
  width: 100%;
}

.status-message {
  font-size: 32rpx;
  color: #7F8C8D;
  margin-bottom: 40rpx;
  line-height: 1.5;
  display: block;
}

.status-message-container {
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 15rpx;
  width: 100%;
}

.status-message-line {
  font-size: 32rpx;
  color: #7F8C8D;
  line-height: 1.6;
  display: block;
  text-align: center;
  white-space: nowrap;
  overflow: visible;
  width: 100%;
  padding: 10rpx 0;
}

.game-btn {
  background: linear-gradient(135deg, #4ECDC4 0%, #45B7D1 100%);
  color: white;
  border: none;
  border-radius: 35rpx;
  padding: 30rpx 60rpx;
  font-size: 36rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  box-shadow: 0 12rpx 24rpx rgba(78, 205, 196, 0.3);
  pointer-events: auto;
  min-width: 250rpx;
  margin-top: 20rpx;
}

.game-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 15rpx 30rpx rgba(78, 205, 196, 0.4);
}

.game-btn:active {
  transform: translateY(0);
}

.primary-btn {
  /* 主要按钮样式，可以在这里添加特定的样式 */
}

/* 游戏状态指示器 */
.game-status {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 50;
  pointer-events: none;
}

.combo-display {
  background: rgba(255, 215, 0, 0.9);
  border-radius: 25rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  animation: comboPulse 0.5s ease-out;
}

.combo-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #2C3E50;
  display: block;
  text-align: center;
}

.level-display {
  background: rgba(155, 89, 182, 0.9);
  border-radius: 25rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  animation: levelUp 1s ease-out;
}

.level-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 8rpx;
  text-align: center;
}

.level-value {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  display: block;
  text-align: center;
}

/* 设置面板 */
.settings-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(10px);
  animation: fadeIn 0.3s ease-out;
}

.settings-content {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 40rpx;
  padding: 60rpx 50rpx;
  width: 85%;
  max-width: 700rpx;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  animation: slideUp 0.3s ease-out;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.settings-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 30rpx;
  text-align: center;
}

.setting-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ECF0F1;
}

.setting-label {
  font-size: 32rpx;
  color: #2C3E50;
  font-weight: 500;
}

.setting-control {
  display: flex;
  align-items: center;
}

.switch {
  transform: scale(0.8);
}

.picker {
  background: #ECF0F1;
  border-radius: 15rpx;
  padding: 15rpx 25rpx;
  font-size: 28rpx;
  color: #2C3E50;
  min-width: 120rpx;
}

.settings-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 40rpx;
}

/* 动画效果 */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes comboPulse {
  0% {
    transform: scale(0.8);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes levelUp {
  0% {
    transform: translateX(-50%) scale(0.5);
    opacity: 0;
  }
  50% {
    transform: translateX(-50%) scale(1.1);
    opacity: 1;
  }
  100% {
    transform: translateX(-50%) scale(1);
    opacity: 1;
  }
}

@keyframes bubbleFloat {
  0%, 100% {
    transform: translateY(0rpx);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .bubble-pop-game {
    width: 100vw;
    overflow-x: hidden;
  }

  .game-canvas-container {
    top: 80rpx;
    left: 20rpx;
    right: 20rpx;
    bottom: 120rpx;
  }

  .game-controls {
    bottom: 15rpx;
    gap: 10rpx;
    max-width: 95%;
  }

  .control-btn {
    padding: 12rpx 16rpx;
    font-size: 22rpx;
    min-width: 85rpx;
    max-width: 100rpx;
    flex: 1;
  }

  .control-btn .btn-icon {
    font-size: 20rpx;
  }

  .overlay-title {
    font-size: 36rpx;
  }

  .overlay-message {
    font-size: 22rpx;
  }

  .overlay-score {
    font-size: 28rpx;
  }

  .status-overlay {
    padding: 50rpx 30rpx;
    width: 95%;
    max-width: 400rpx;
    min-width: 350rpx;
  }

  .status-title {
    font-size: 40rpx;
    margin-bottom: 20rpx;
  }

  .status-message-line {
    font-size: 24rpx;
    padding: 8rpx 0;
  }

  .game-btn {
    padding: 20rpx 35rpx;
    font-size: 28rpx;
    min-width: 200rpx;
  }

  .settings-content {
    width: 90%;
    padding: 35rpx 25rpx;
    max-width: 350rpx;
  }

  .setting-label {
    font-size: 22rpx;
  }

  .setting-control {
    font-size: 20rpx;
  }

  .game-ui {
    top: 20rpx;
    left: 20rpx;
    right: 20rpx;
    gap: 15rpx;
  }

  .score-display,
  .time-display,
  .combo-display,
  .level-display {
    padding: 15rpx 20rpx;
  }

  .score-label,
  .time-label,
  .level-label {
    font-size: 22rpx;
  }

  .score-value,
  .time-value,
  .level-value {
    font-size: 32rpx;
  }

  .combo-text {
    font-size: 28rpx;
  }
}

@media (min-width: 768px) {
  .game-header {
    padding: 40rpx;
  }

  .score-display,
  .time-display {
    padding: 25rpx 35rpx;
  }

  .score-label,
  .time-label {
    font-size: 32rpx;
  }

  .score-value,
  .time-value {
    font-size: 56rpx;
  }

  .game-canvas-container {
    top: 160rpx;
    left: 60rpx;
    right: 60rpx;
    bottom: 200rpx;
  }

  .game-controls {
    bottom: 60rpx;
    gap: 30rpx;
  }

  .control-btn {
    padding: 25rpx 35rpx;
    font-size: 32rpx;
    min-width: 140rpx;
  }

  .overlay-title {
    font-size: 56rpx;
  }

  .overlay-message {
    font-size: 36rpx;
  }

  .overlay-score {
    font-size: 48rpx;
  }

  .status-overlay {
    padding: 100rpx 80rpx;
    width: 85%;
    max-width: 700rpx;
    min-width: 600rpx;
  }

  .status-title {
    font-size: 60rpx;
  }

  .status-message-line {
    font-size: 36rpx;
  }

  .game-btn {
    padding: 35rpx 70rpx;
    font-size: 40rpx;
    min-width: 300rpx;
  }

  .settings-content {
    width: 70%;
    max-width: 800rpx;
    padding: 80rpx 60rpx;
  }

  .setting-label {
    font-size: 36rpx;
  }

  .setting-control {
    font-size: 32rpx;
  }
}