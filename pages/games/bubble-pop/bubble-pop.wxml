<view class="bubble-pop-game">
  <view class="game-canvas-container">
    <canvas
      id="bubbleCanvas"
      canvas-id="bubbleCanvas"
      class="game-canvas"
      bindtouchstart="onCanvasTouch"
      type="2d"
      style="pointer-events: {{gameStatus === 'playing' ? 'auto' : 'none'}}; visibility: {{gameStatus === 'playing' ? 'visible' : 'hidden'}};"
    ></canvas>

    <view class="game-ui" wx:if="{{gameStatus === 'playing'}}">
      <view class="score-display">
        <text class="score-label">分数</text>
        <text class="score-value">{{score}}</text>
      </view>

      <view class="time-display">
        <text class="time-label">时间</text>
        <text class="time-value">{{timeLeft}}s</text>
      </view>

      <view class="combo-display" wx:if="{{combo > 1}}">
        <text class="combo-text">连击 x{{combo}}</text>
      </view>

      <view class="level-display">
        <text class="level-label">等级</text>
        <text class="level-value">{{level}}</text>
      </view>
    </view>

    <view class="play-hint" wx:if="{{gameStatus === 'playing' && score === 0}}">
      点击亮色泡泡，避开黑色泡泡
    </view>

  </view>

  <view class="entry-panel" wx:if="{{gameStatus !== 'playing'}}">
    <view class="entry-card">
      <view class="entry-visual">
        <text class="entry-pop pop-one"></text>
        <text class="entry-pop pop-two"></text>
        <text class="entry-pop pop-three"></text>
        <text class="entry-pop pop-four"></text>
      </view>
      <text class="status-title">{{statusTitle}}</text>
      <view class="status-message-container" wx:if="{{gameStatus === 'ended'}}">
        <text class="status-message-line">最终得分: {{score}}</text>
        <text class="status-message-line">最高连击: {{maxCombo}}</text>
        <text class="status-message-line">最高等级: {{level}}</text>
      </view>
      <text class="status-message" wx:else>{{statusMessage}}</text>
      <view class="status-tips" wx:if="{{gameStatus === 'ready' || gameStatus === 'paused'}}">
        <view class="tip-item">彩色泡泡：获得分数</view>
        <view class="tip-item">连续命中：提升连击奖励</view>
        <view class="tip-item">黑色泡泡：尽量避开</view>
      </view>
      <button class="game-btn primary-btn" wx:if="{{gameStatus === 'paused'}}" bindtap="resumeGame">
        继续游戏
      </button>
      <button class="game-btn primary-btn" wx:elif="{{gameStatus === 'loading' || gameStatus === 'initializing' || gameStatus === 'restarting'}}" disabled="{{true}}">
        {{gameButtonText}}
      </button>
      <button class="game-btn primary-btn" wx:else bindtap="startGame">{{gameButtonText}}</button>
      <button class="entry-secondary-btn" bindtap="openSettings">游戏设置</button>
    </view>
  </view>

  <view class="game-controls" wx:if="{{gameStatus === 'playing' || gameStatus === 'paused'}}">
    <button class="control-btn pause-btn" bindtap="pauseGame" wx:if="{{gameStatus === 'playing'}}">
      <text class="btn-icon">⏸️</text>
      暂停
    </button>

    <button class="control-btn resume-btn" bindtap="resumeGame" wx:if="{{gameStatus === 'paused'}}">
      <text class="btn-icon">▶️</text>
      继续
    </button>

    <button class="control-btn restart-btn" bindtap="restartGame">
      <text class="btn-icon">🔄</text>
      重新开始
    </button>

    <button class="control-btn settings-btn" bindtap="openSettings">
      <text class="btn-icon">⚙️</text>
      设置
    </button>
  </view>

  <view class="game-settings" wx:if="{{showSettings}}">
    <view class="settings-panel">
      <view class="settings-header">
        <text class="settings-title">游戏设置</text>
        <button class="close-btn" bindtap="closeSettings">✕</button>
      </view>

      <view class="setting-group">
        <text class="setting-label">音效</text>
        <switch checked="{{soundEnabled}}" bindchange="toggleSound"></switch>
      </view>

      <view class="setting-group">
        <text class="setting-label">背景音乐</text>
        <switch checked="{{musicEnabled}}" bindchange="toggleMusic"></switch>
      </view>

      <view class="setting-group">
        <text class="setting-label">游戏时长</text>
        <picker bindchange="changeGameDuration" value="{{gameDurationIndex}}" range="{{durationOptions}}">
          <view class="picker-value">{{durationOptions[gameDurationIndex]}}</view>
        </picker>
      </view>

      <view class="setting-group">
        <text class="setting-label">难度等级</text>
        <picker bindchange="changeDifficulty" value="{{difficultyIndex}}" range="{{difficultyOptions}}">
          <view class="picker-value">{{difficultyOptions[difficultyIndex]}}</view>
        </picker>
      </view>
    </view>
  </view>
</view>
